# ============================================================
# 基础设施配置 — 复制为 .env 后修改
# ============================================================

# ── PostgreSQL 超级用户 ───────────────────────────────────
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=postgres123

# ── CPA 配置 ─────────────────────────────────────────────
CPA_PORT=8317
CPA_MANAGEMENT_PASSWORD=changeme
CPA_DB_USER=cliproxy
CPA_DB_PASSWORD=cliproxy123
CPA_DB_NAME=cliproxy

# ── New API 配置 ──────────────────────────────────────────
NEWAPI_PORT=3480
NEWAPI_DB_USER=newapi
NEWAPI_DB_PASSWORD=newapi123
NEWAPI_DB_NAME=newapi

# ── 网络代理（没有科学上网需求可留空）─────────────────────
HTTP_PROXY=
HTTPS_PROXY=
